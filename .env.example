# ── 0G mode ────────────────────────────────────────────────────────────────
# "live"  -> real 0G Compute + Storage (needs a funded OG_PRIVATE_KEY below)
# "mock"  -> deterministic local fallback (no testnet funds required)
# Recommended default for local dev is "mock" so no real key is ever needed
# on a laptop. Use "live" only on the deployed server.
OG_MODE=mock

# Server wallet that pays for inference + storage on 0G testnet.
# SECURITY: this key signs paid inference + on-chain txs. Never commit it, never
# reuse a personal wallet, and rotate immediately if it is ever exposed. In
# production set it as an encrypted env var (e.g. `vercel env add OG_PRIVATE_KEY`),
# NOT in a plaintext file. Leave blank locally and rely on OG_MODE=mock.
# Fund the deployed wallet from the faucet: https://faucet.0g.ai
OG_PRIVATE_KEY=

# ── Network (defaults are 0G Galileo testnet) ───────────────────────────────
OG_RPC_URL=https://evmrpc-testnet.0g.ai
OG_CHAIN_ID=16602
OG_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai

# ── Compute funding (in OG) ─────────────────────────────────────────────────
# Ledger is created on first run if missing; per-provider sub-account is funded lazily.
OG_LEDGER_OG=0.05
OG_PROVIDER_FUND_OG=0.02
